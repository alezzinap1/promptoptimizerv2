OPENROUTER_API_KEY=
# Optional: default OpenRouter model id for POST /api/image/try (e.g. google/gemini-2.5-flash-image)
# IMAGE_TRY_MODEL=
DB_PATH=data/web_agent.db

# Phase 1: config and abuse protection
APP_ENV=dev
MAX_INPUT_CHARS=50000
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SEC=60
# Auth: per IP (in-memory; one worker)
AUTH_REGISTER_RATE_LIMIT_REQUESTS=5
AUTH_REGISTER_RATE_WINDOW_SEC=3600
AUTH_LOGIN_RATE_LIMIT_REQUESTS=25
AUTH_LOGIN_RATE_WINDOW_SEC=60
# Web session lifetime after login/register (hours)
SESSION_TTL_HOURS=24
# Fernet key for encrypting per-user OpenRouter keys in SQLite (required for public deploy)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
USER_API_KEY_FERNET_SECRET=
BUDGET_GENERATIONS_PER_SESSION=50
LLM_TIMEOUT_SEC=120
TRIAL_TOKENS_LIMIT=50000
TRIAL_MAX_COMPLETION_PER_M=1.0

# CORS (for production: https://your-domain.com)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# GitHub OAuth (register at github.com/settings/developers)
# Callback URL must be: https://your-domain.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Frontend URL for post-OAuth redirect (production URL)
FRONTEND_URL=https://metaprompt.online

# Observability (optional)
SENTRY_DSN=
LOG_LEVEL=INFO
# Debug: log model + messages for each OpenRouter chat.completions call (server logs only; can be very large).
# OPENROUTER_LOG_REQUEST_BODIES=1
# OPENROUTER_LOG_MAX_CHARS=262144

# Phase 2: storage migration
POSTGRES_DSN=
