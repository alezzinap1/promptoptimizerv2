OPENROUTER_API_KEY=
DB_PATH=data/web_agent.db

# Phase 1: config and abuse protection
APP_ENV=dev
MAX_INPUT_CHARS=50000
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SEC=60
BUDGET_GENERATIONS_PER_SESSION=50
LLM_TIMEOUT_SEC=120

# CORS (for production: https://your-domain.com)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Observability (optional)
SENTRY_DSN=
LOG_LEVEL=INFO

# Phase 2: storage migration
POSTGRES_DSN=
